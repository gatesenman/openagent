# OpenAgent 环境变量配置
# 复制此文件为 .env 并填入实际值

# ==================== 基础配置 ====================
APP_NAME=OpenAgent
APP_VERSION=0.1.0
DEBUG=true

# ==================== 数据库 ====================
DATABASE_URL=postgresql://openagent:openagent_dev@localhost:5432/openagent
POSTGRES_DB=openagent
POSTGRES_USER=openagent
POSTGRES_PASSWORD=openagent_dev

# ==================== LLM 配置 ====================
# 提供商: openai / deepseek / qwen / anthropic / ollama
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek (推荐国内使用)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 通义千问
QWEN_API_KEY=sk-your-qwen-key
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Ollama (本地模型)
OLLAMA_BASE_URL=http://localhost:11434

# ==================== 沙箱配置 ====================
# 类型: docker / local
SANDBOX_TYPE=docker
SANDBOX_DOCKER_IMAGE=ubuntu:22.04
SANDBOX_CPU_LIMIT=2
SANDBOX_MEMORY_LIMIT=2g
SANDBOX_TIMEOUT=3600

# ==================== 协议配置 ====================
MCP_ENABLED=true
AGUI_ENABLED=true

# ==================== 前端 ====================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_DEFAULT_LOCALE=zh

# ==================== 安全 ====================
SECRET_KEY=your-secret-key-change-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
